{
  "name": "quantara-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.js",
    "package": "node esbuild.config.js && cd dist && zip -r lambda.zip index.js",
    "typecheck": "tsc --noEmit",
    "dev": "AWS_REGION=us-west-2 AWS_PROFILE=quantara-dev TABLE_PREFIX=quantara-dev- CORS_ORIGIN=* SKIP_API_KEY=true SKIP_IP_WHITELIST=true tsx --watch src/local.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-cloudwatch": "^3.750.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-ecs": "^3.750.0",
    "@aws-sdk/client-lambda": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/client-ssm": "^3.1036.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@hono/zod-openapi": "^1.3.0",
    "@quantara/shared": "*",
    "@scalar/hono-api-reference": "^0.10.10",
    "hono": "^4.7.0",
    "ipaddr.js": "^2.3.0",
    "jose": "^6.0.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
