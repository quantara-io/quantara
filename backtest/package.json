{
  "name": "quantara-backtest",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./cost/estimator-pure": "./src/cost/estimator-pure.ts",
    "./runner/main": "./src/runner/main.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "smoke": "tsx src/smoke.ts",
    "backtest": "tsx src/cli.ts",
    "backtest:estimate": "tsx src/cli.ts estimate",
    "runner": "tsx src/runner/main.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/client-sqs": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@quantara/shared": "*",
    "quantara-ingestion": "*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
